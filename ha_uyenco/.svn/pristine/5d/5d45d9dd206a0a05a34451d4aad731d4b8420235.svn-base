package perfectapp

class PerfectNumberChecker {
    static isPerfectNumber(def number){ //Feedback: please use 2-space indentations
        if (number <= 1) return false  
        def result = 1
        2.upto(number){ factor->
            if(number % factor == 0) result += factor
        }
        result == number * 2
    }
}
