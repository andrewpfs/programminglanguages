

import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;

class impAssign1Test {

    @Test
    void knownPerfectsAreTrue() {
        assertTrue(impAssign1.perfectNumber(6));
        assertTrue(impAssign1.perfectNumber(28));
        assertTrue(impAssign1.perfectNumber(496));
        assertTrue(impAssign1.perfectNumber(8128));
    }

    @Test
    void obviousNonPerfectsAreFalse() {
        assertFalse(impAssign1.perfectNumber(1));  
        assertFalse(impAssign1.perfectNumber(2));
        assertFalse(impAssign1.perfectNumber(3));
        assertFalse(impAssign1.perfectNumber(12));
    }

}
