package fib_app

object FibonacciAppRecursiveAndIterative {
  def fibonacciSeriesRecursiveAndIterative(position : Int): List[Int] = position match {
    case 0 => List(1) 
    case 1 => List(1,1) 
    case _ => 
      val series = fibonacciSeriesRecursiveAndIterative(position - 1) // calls recursion and gets back the old list
      val nextVal = series.takeRight(2).sum  // this gets the new number
      series :+ nextVal // adds the new value
  } 
}
