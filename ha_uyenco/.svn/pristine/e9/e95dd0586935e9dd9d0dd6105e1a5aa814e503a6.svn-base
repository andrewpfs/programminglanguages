public class assignment1 {
    public static void main(String [] args){
        for(int k  = 0; k < 10000; k++)//test case for first 10000 numbers
        { 
            int num = k;
            int result = 1;
            for(int i =2; i <= num/2 ; i++){      
                if(num % i == 0){
                    result += i;
                }  
            }
            
            if(result == num && result != 1){
                System.out.println(num + " is a perfect number"); 
            }
        }
    }
